function toggleLive(){jarvisToggle();}
function endLive(){jarvisStop();}
window.speechSynthesis && window.speechSynthesis.getVoices();

// ══ TRADING ════════════════════════════════════════════════════
async function askSignal() {
  const inp = document.getElementById('trade-input');
  const q = inp.value.trim();
  if (!q) return;
  inp.value = '';
  const container = document.getElementById('trading-content');
  const loading = document.createElement('div');
  loading.style.cssText = 'font-family:Share Tech Mono,monospace;font-size:0.72rem;color:var(--muted2);letter-spacing:0.1em;padding:12px 0;';
  loading.textContent = '// ANALYSE EN COURS...';
  container.appendChild(loading);
  container.scrollTop = container.scrollHeight;
  try {
    const res = await fetch('/.netlify/functions/chat', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ system:`Tu es ASTRA Trading, un expert en analyse technique. Pour chaque paire ou actif demandé, donne: signal (BUY/SELL/WAIT), prix d'entrée, take profit, stop loss, analyse courte (2-3 phrases), et niveau de confiance en %. Réponds en français, de façon concise et professionnelle.`,
        messages:[{role:'user',content:q}] })
    });
    const data = await res.json();
    loading.remove();
    const reply = data.content?.[0]?.text || 'Erreur.';
    const card = document.createElement('div');
    card.className='signal-card wait';
    card.innerHTML=`<div class="signal-top"><span class="signal-pair">${q.toUpperCase().substring(0,20)}</span><span class="signal-action action-wait">🤖 ASTRA IA</span></div><div class="signal-analysis">${reply.replace(/\n/g,'<br>')}</div>`;
    container.appendChild(card);
    container.scrollTop = container.scrollHeight;
  } catch(e) { loading.textContent = '// ERREUR DE CONNEXION'; }
}

// ══ CODE ENGINE ════════════════════════════════════════════════
async function analyzeCode() {
  const code = document.getElementById('code-editor').value.trim();
  const lang = document.getElementById('code-lang').value;
  const out = document.getElementById('code-output');
  if (!code) return;
  out.innerHTML = '<span style="color:var(--muted)">// Analyse en cours...</span>';
  try {
    const res = await fetch('/.netlify/functions/chat', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ system:`Analyse ce code ${lang}. Donne: 1) Explication 2) Problèmes 3) Améliorations 4) Simulation de sortie. Sois concis.`,
        messages:[{role:'user',content:`Code ${lang}:\n${code}`}] })
    });
    const data = await res.json();
    const reply = data.content?.[0]?.text || 'Erreur.';
    out.textContent = '// ANALYSE ASTRA\n\n' + reply;
  } catch(e) { out.innerHTML='<span style="color:#FF4455">// ERREUR</span>'; }
}

// ══ HISTORY ════════════════════════════════════════════════════
function saveToHistory(userMsg, aiReply) {
  const entry = { id:Date.now(), title:userMsg.substring(0,60), preview:aiReply.substring(0,80), time:new Date().toLocaleString('fr-FR',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) };
  chatHistory.unshift(entry);
  localStorage.setItem('astraHistory', JSON.stringify(chatHistory.slice(0,50)));
  renderHistory();
}
function loadHistoryFromStorage() {
  const stored = localStorage.getItem('astraHistory');
  if (stored) { chatHistory = JSON.parse(stored); renderHistory(); }
}
function renderHistory() {
  const list = document.getElementById('history-list');
  const empty = document.getElementById('history-empty');
  if (chatHistory.length === 0) { if(empty) empty.style.display='flex'; return; }
  if(empty) empty.style.display='none';
  list.innerHTML = '';
  chatHistory.forEach(e => {
    const item = document.createElement('div');
    item.className = 'history-item';
    item.innerHTML = `<div class="history-item-title">${e.title}</div><div class="history-item-meta">${e.time}</div><div class="history-item-preview">${e.preview}...</div>`;
    item.onclick = () => { switchMode('chat'); };
    list.appendChild(item);
  });
}
function clearHistory() {
  chatHistory = []; localStorage.removeItem('astraHistory');
  document.getElementById('history-list').innerHTML = '<div class="history-empty" id="history-empty">// AUCUNE CONVERSATION //</div>';
}

