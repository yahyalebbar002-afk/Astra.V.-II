<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ASTRA.V. II</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@300;400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box;}
:root{
  --red:#C8000A;--red-glow:#FF1525;--red-dim:rgba(200,0,10,0.12);
  --black:#06060A;--dark:#0C0C12;--surface:#111118;--card:#17171E;
  --border:rgba(255,255,255,0.07);--border-red:rgba(200,0,10,0.35);
  --text:#F0EAF2;--muted:#56566A;--muted2:#8888A2;
  --gold:#D4A017;--gold-dim:rgba(212,160,23,0.12);
}
html,body{height:100%;overflow:hidden;background:var(--black);}
body{color:var(--text);font-family:"Rajdhani",sans-serif;}

/* ══ INTRO ══════════════════════════════════════════════════════════ */
#intro{position:fixed;inset:0;z-index:999;overflow:hidden;background:#8B0000;}
#intro.fade-out{animation:introOut 1s ease-in forwards;}
@keyframes introOut{to{opacity:0;pointer-events:none;}}

/* PC background - image 1 (landscape panther) */
.intro-bg-pc{
  position: absolute;
  inset: 0;
  background: url("https://i.ibb.co/d4x4HY9G/716529976-1682656123052246-8366534831698051886-n.jpg")
              center / cover no-repeat;
  filter: brightness(0.82);
}
/* Mobile background - image 2 (portrait panther) */
.intro-bg-mobile{
  position:absolute;inset:0;
  background:url("data:image/png;base64,") center/cover no-repeat;
  filter:brightness(0.82);
  display:none;
}
.intro-overlay{
  position:absolute;inset:0;
  background:linear-gradient(180deg,rgba(0,0,0,0) 40%,rgba(0,0,0,0.5) 75%,rgba(0,0,0,0.82) 100%);
}
.intro-scanlines{
  position:absolute;inset:0;pointer-events:none;
  background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,0,0,0.016) 3px,rgba(0,0,0,0.016) 4px);
}

/* PC layout: title LEFT side, button bottom-left */
.intro-content-pc{
  position:absolute;left:6%;bottom:10%;
  display:flex;flex-direction:column;align-items:flex-start;gap:10px;
  animation:slideInLeft 1s 0.5s ease-out both;
}
@keyframes slideInLeft{from{opacity:0;transform:translateX(-30px);}to{opacity:1;transform:none;}}
.intro-logo-pc{
  font-family:"Bebas Neue",sans-serif;
  font-size:clamp(3.5rem,7vw,6.5rem);
  letter-spacing:0.1em;line-height:1;color:#fff;
  text-shadow:3px 3px 0 #000,-1px -1px 0 rgba(0,0,0,0.7),0 4px 20px rgba(0,0,0,0.9);
  -webkit-text-stroke:1.5px rgba(0,0,0,0.5);
}
.intro-sub-pc{
  font-family:"Rajdhani",sans-serif;font-size:1rem;font-weight:500;
  letter-spacing:0.25em;color:rgba(255,255,255,0.6);text-transform:uppercase;
}

/* Mobile layout: title TOP, button BOTTOM */
.intro-content-mobile{
  position:absolute;top:0;left:0;right:0;bottom:0;
  display:none;flex-direction:column;justify-content:space-between;
  padding:12% 8% 10%;
  animation:fadeIn 0.8s 0.4s ease-out both;
}
@keyframes fadeIn{from{opacity:0;}to{opacity:1;}}
.intro-logo-mobile{
  font-family:"Bebas Neue",sans-serif;
  font-size:clamp(2.8rem,12vw,4.5rem);
  letter-spacing:0.1em;line-height:1;color:#fff;
  text-shadow:2px 2px 0 #000,0 3px 15px rgba(0,0,0,0.9);
  -webkit-text-stroke:1px rgba(0,0,0,0.5);
  align-self:center;text-align:center;
}
.intro-sub-mobile{
  font-family:"Rajdhani",sans-serif;font-size:0.85rem;font-weight:500;
  letter-spacing:0.2em;color:rgba(255,255,255,0.55);text-transform:uppercase;
  text-align:center;margin-top:6px;
}
.mobile-bottom{display:flex;flex-direction:column;align-items:center;gap:14px;}

/* shared enter button */
.intro-enter-btn{
  font-family:"Bebas Neue",sans-serif;font-size:1rem;letter-spacing:0.22em;
  padding:13px 40px;border:1px solid rgba(255,255,255,0.55);
  background:rgba(0,0,0,0.35);color:#fff;cursor:pointer;
  transition:.3s;position:relative;overflow:hidden;backdrop-filter:blur(8px);
}
.intro-enter-btn::before{
  content:'';position:absolute;inset:0;background:rgba(200,0,10,0.75);
  transform:scaleX(0);transform-origin:left;transition:.4s;z-index:-1;
}
.intro-enter-btn:hover::before,.intro-enter-btn:active::before{transform:scaleX(1);}

/* ══ RESPONSIVE INTRO SWITCH ════════════════════════════════════════ */
@media(max-width:640px){
  .intro-bg-pc,.intro-content-pc{display:none!important;}
  .intro-bg-mobile,.intro-content-mobile{display:flex!important;}
}
@media(min-width:641px){
  .intro-bg-mobile,.intro-content-mobile{display:none!important;}
  .intro-content-pc{display:flex!important;}
}

/* ══ LOGIN ══════════════════════════════════════════════════════════ */
#login-screen{
  position:fixed;inset:0;z-index:99;display:none;align-items:center;justify-content:center;
  background:radial-gradient(ellipse at center,rgba(20,5,5,1),var(--black) 70%);
}
#login-screen.active{display:flex;animation:fadeIn 0.5s ease-out;}
.login-wrap{width:min(400px,calc(100%-40px));text-align:center;}
.login-logo-mark{font-family:"Bebas Neue",sans-serif;font-size:3rem;letter-spacing:0.1em;color:var(--red);text-shadow:0 0 30px rgba(200,0,10,0.5);display:block;margin-bottom:4px;}
.login-title{font-family:"Bebas Neue",sans-serif;font-size:1.8rem;letter-spacing:0.06em;color:#fff;margin-bottom:4px;}
.login-desc{color:var(--muted2);font-size:0.85rem;margin-bottom:28px;font-weight:400;}
.login-box{background:rgba(12,12,18,0.9);border:1px solid var(--border);padding:32px 28px;position:relative;}
.login-corner{position:absolute;width:14px;height:14px;border-color:rgba(200,0,10,0.4);border-style:solid;}
.corner-tl{top:0;left:0;border-width:1px 0 0 1px;}
.corner-tr{top:0;right:0;border-width:1px 1px 0 0;}
.corner-bl{bottom:0;left:0;border-width:0 0 1px 1px;}
.corner-br{bottom:0;right:0;border-width:0 1px 1px 0;}
.login-fields{display:flex;flex-direction:column;gap:12px;margin-bottom:16px;}
.login-input{width:100%;padding:13px 16px;background:rgba(255,255,255,0.03);border:1px solid var(--border);color:var(--text);font-family:"Rajdhani",sans-serif;font-size:0.9rem;font-weight:500;letter-spacing:0.04em;outline:none;transition:.2s;}
.login-input:focus{border-color:var(--border-red);background:rgba(200,0,10,0.04);}
.login-input::placeholder{color:var(--muted);}
.login-submit{width:100%;padding:14px;background:var(--red);border:none;color:#fff;font-family:"Bebas Neue",sans-serif;font-size:1rem;letter-spacing:0.2em;cursor:pointer;transition:.2s;}
.login-submit:hover{background:var(--red-glow);}
.login-status{height:18px;font-family:"Share Tech Mono",monospace;font-size:0.7rem;color:var(--red);letter-spacing:0.06em;margin-top:8px;}
.login-tabs{display:flex;margin-bottom:20px;border:1px solid var(--border);}
.login-tab{flex:1;padding:9px;background:transparent;border:none;color:var(--muted);font-family:"Bebas Neue",sans-serif;font-size:0.85rem;letter-spacing:0.12em;cursor:pointer;transition:.2s;}
.login-tab.active{background:var(--red);color:#fff;}

/* ══ APP ════════════════════════════════════════════════════════════ */
#app{position:fixed;inset:0;display:none;}
#app.active{display:flex;}

/* ══ SIDEBAR ════════════════════════════════════════════════════════ */
.sidebar{
  width:66px;background:var(--dark);border-right:1px solid var(--border);
  display:flex;flex-direction:column;align-items:center;padding:16px 0;gap:4px;
  flex-shrink:0;position:relative;z-index:10;
}
.sidebar::after{
  content:'';position:absolute;right:0;top:20%;bottom:20%;width:1px;
  background:linear-gradient(180deg,transparent,rgba(200,0,10,0.3),transparent);
}
.sb-logo{font-family:"Bebas Neue",sans-serif;font-size:1.2rem;letter-spacing:0.08em;color:var(--red);margin-bottom:16px;cursor:pointer;text-shadow:0 0 12px rgba(200,0,10,0.5);}
.sb-btn{
  width:40px;height:40px;border-radius:6px;border:none;background:transparent;
  display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;
  cursor:pointer;color:var(--muted);transition:.2s;position:relative;
}
.sb-btn svg{width:17px;height:17px;stroke:currentColor;fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round;}
.sb-btn .sb-label{font-family:"Share Tech Mono",monospace;font-size:0.38rem;letter-spacing:0.05em;text-transform:uppercase;}
.sb-btn:hover{color:var(--text);background:rgba(255,255,255,0.04);}
.sb-btn.active{color:var(--red);background:var(--red-dim);}
.sb-btn.active::before{content:'';position:absolute;left:0;top:25%;bottom:25%;width:2px;background:var(--red);border-radius:0 2px 2px 0;}
.sb-btn.vip-btn{color:var(--gold)!important;background:var(--gold-dim)!important;}
.sb-btn.vip-btn::before{background:var(--gold)!important;}
.sb-divider{width:28px;height:1px;background:var(--border);margin:4px 0;}
.sb-spacer{flex:1;}
.sb-avatar{
  width:32px;height:32px;border-radius:4px;
  background:linear-gradient(135deg,var(--red),#600008);
  display:flex;align-items:center;justify-content:center;
  font-family:"Bebas Neue",sans-serif;font-size:0.7rem;color:#fff;letter-spacing:0.05em;
  border:1px solid var(--border-red);cursor:pointer;position:relative;
}
.vip-crown{position:absolute;top:-8px;right:-6px;font-size:0.75rem;}

/* ══ MAIN ══════════════════════════════════════════════════════════ */
.main-area{flex:1;display:flex;flex-direction:column;overflow:hidden;min-width:0;}
.topbar{
  height:50px;background:rgba(6,6,10,0.96);border-bottom:1px solid var(--border);
  display:flex;align-items:center;padding:0 18px;gap:12px;flex-shrink:0;
}
.topbar-title{font-family:"Bebas Neue",sans-serif;font-size:0.95rem;letter-spacing:0.08em;flex:1;}
.topbar-status{display:flex;align-items:center;gap:6px;}
.status-dot{width:5px;height:5px;border-radius:50%;background:#00D97E;animation:pulse2 2s infinite;box-shadow:0 0 5px rgba(0,217,126,0.6);}
@keyframes pulse2{0%,100%{opacity:1;}50%{opacity:.3;}}
.topbar-status span{font-size:0.65rem;color:var(--muted2);font-family:"Share Tech Mono",monospace;}
.mode-tabs{display:flex;gap:2px;background:var(--surface);border:1px solid var(--border);padding:2px;}
.mode-tab{padding:4px 10px;border:none;background:transparent;font-family:"Bebas Neue",sans-serif;font-size:0.72rem;letter-spacing:0.12em;color:var(--muted);cursor:pointer;transition:.15s;display:flex;align-items:center;gap:5px;white-space:nowrap;}
.mode-tab svg{width:12px;height:12px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;}
.mode-tab.active{background:var(--red);color:#fff;}
.mode-tab.vip-tab.active{background:var(--gold);color:#000;}
.mode-tab:not(.active):hover{color:var(--text);}

/* ══ CONTENT ══════════════════════════════════════════════════════ */
.content{flex:1;overflow:hidden;display:flex;flex-direction:column;}
.view{display:none;flex:1;flex-direction:column;overflow:hidden;}
.view.active{display:flex;}

/* ══ CHAT ══════════════════════════════════════════════════════════ */
.chat-area{flex:1;overflow-y:auto;padding:18px 24px;display:flex;flex-direction:column;gap:16px;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.chat-area::-webkit-scrollbar{width:3px;}
.chat-area::-webkit-scrollbar-thumb{background:var(--border);}
.msg-row{display:flex;gap:9px;max-width:660px;}
.msg-row.user{flex-direction:row-reverse;align-self:flex-end;margin-left:auto;}
.msg-row.ai{align-self:flex-start;}
.msg-av{width:28px;height:28px;border-radius:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-family:"Bebas Neue",sans-serif;font-size:0.55rem;letter-spacing:0.04em;}
.msg-av.ai-av{background:linear-gradient(135deg,var(--red),#5A0008);color:#fff;}
.msg-av.user-av{background:var(--card);border:1px solid var(--border);color:var(--muted2);}
.msg-col{display:flex;flex-direction:column;gap:3px;}
.msg-bubble{padding:11px 14px;border-radius:7px;font-size:0.87rem;line-height:1.65;font-weight:400;}
.msg-row.ai .msg-bubble{background:var(--card);border:1px solid var(--border);border-bottom-left-radius:2px;}
.msg-row.user .msg-bubble{background:var(--red);color:#fff;border-bottom-right-radius:2px;}
.msg-time{font-size:0.6rem;color:var(--muted);font-family:"Share Tech Mono",monospace;}
.msg-row.user .msg-time{text-align:right;}
.typing-dots{display:flex;gap:4px;align-items:center;padding:2px 0;}
.typing-dots span{width:5px;height:5px;border-radius:50%;background:var(--muted);animation:tdot 1.2s infinite;}
.typing-dots span:nth-child(2){animation-delay:.2s;}
.typing-dots span:nth-child(3){animation-delay:.4s;}
@keyframes tdot{0%,80%,100%{transform:translateY(0);}40%{transform:translateY(-5px);}}

/* Empty state */
.empty-state{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;padding:40px;text-align:center;}
.empty-logo{font-family:"Bebas Neue",sans-serif;font-size:clamp(2rem,5vw,3rem);letter-spacing:0.06em;}
.empty-logo span{color:var(--red);}
.empty-state p{font-size:0.82rem;color:var(--muted);max-width:360px;line-height:1.6;}
.suggestions{display:flex;flex-wrap:wrap;gap:7px;justify-content:center;margin-top:10px;}
.sug-chip{padding:7px 14px;border:1px solid var(--border);background:var(--card);font-size:0.75rem;color:var(--muted2);cursor:pointer;transition:.2s;font-family:"Rajdhani",sans-serif;font-weight:500;letter-spacing:0.03em;}
.sug-chip:hover{border-color:var(--border-red);color:var(--text);}

/* Input bar */
.input-bar{padding:12px 18px;border-top:1px solid var(--border);background:rgba(6,6,10,0.97);flex-shrink:0;}
.input-wrap{display:flex;align-items:center;gap:8px;background:var(--card);border:1px solid var(--border);padding:6px 6px 6px 14px;transition:.2s;}
.input-wrap:focus-within{border-color:var(--border-red);}
.input-field{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:"Rajdhani",sans-serif;font-size:0.88rem;font-weight:500;resize:none;max-height:100px;line-height:1.5;padding:3px 0;letter-spacing:0.02em;}
.input-field::placeholder{color:var(--muted);}
.input-actions{display:flex;align-items:center;gap:4px;}
.icon-btn{width:33px;height:33px;border-radius:5px;border:none;background:transparent;display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:.2s;}
.icon-btn:hover{background:var(--red-dim);color:var(--red);}
.icon-btn.mic-active{background:rgba(200,0,10,0.2);color:var(--red);animation:micPulse 1s infinite;}
@keyframes micPulse{0%,100%{box-shadow:0 0 0 0 rgba(200,0,10,0.4);}50%{box-shadow:0 0 0 6px rgba(200,0,10,0);}}
.icon-btn svg{width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;stroke-linejoin:round;}
.send-btn{width:33px;height:33px;border-radius:5px;border:none;background:var(--red);color:#fff;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:.2s;}
.send-btn:hover{background:var(--red-glow);}
.send-btn:disabled{background:var(--surface);color:var(--muted);cursor:not-allowed;}
.send-btn svg{width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2.2;stroke-linecap:round;stroke-linejoin:round;}

/* File input hidden */
#file-input{display:none;}

/* ══ VOICE VIEW ══════════════════════════════════════════════════ */
.voice-view{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:24px;padding:40px;background:radial-gradient(ellipse at center 40%,rgba(200,0,10,0.05),transparent 70%);}
.orb-container{position:relative;width:160px;height:160px;display:flex;align-items:center;justify-content:center;}
.orb-ring{position:absolute;border-radius:50%;border:1px solid;animation:orbRing 3s ease-in-out infinite;}
.orb-ring:nth-child(1){width:100%;height:100%;border-color:rgba(200,0,10,0.12);}
.orb-ring:nth-child(2){width:75%;height:75%;border-color:rgba(200,0,10,0.2);animation-delay:-1s;}
.orb-ring:nth-child(3){width:50%;height:50%;border-color:rgba(200,0,10,0.28);animation-delay:-2s;}
@keyframes orbRing{0%,100%{transform:scale(1);}50%{transform:scale(1.06);}}
.orb-core{width:80px;height:80px;border-radius:50%;background:radial-gradient(circle at 35% 30%,rgba(255,30,50,0.9),rgba(120,0,10,0.95));display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 0 30px rgba(200,0,10,0.4);transition:.3s;position:relative;z-index:2;border:1px solid rgba(255,60,80,0.4);}
.orb-core svg{width:22px;height:22px;stroke:#fff;fill:none;stroke-width:2;stroke-linecap:round;}
.orb-core.listening{animation:orbPulse 1s ease-in-out infinite;box-shadow:0 0 50px rgba(200,0,10,0.7);}
.orb-core.speaking{animation:orbSpeak 0.4s ease-in-out infinite alternate;}
@keyframes orbPulse{0%,100%{transform:scale(1);}50%{transform:scale(1.1);}}
@keyframes orbSpeak{from{transform:scale(0.96);}to{transform:scale(1.07);}}
.live-status{font-family:"Share Tech Mono",monospace;font-size:0.72rem;letter-spacing:0.12em;color:var(--muted2);text-transform:uppercase;}
.live-status.listening-st{color:var(--red);animation:pulse2 1s infinite;}
.live-status.speaking-st{color:#00D97E;}
.live-transcript{max-width:480px;text-align:center;font-size:0.87rem;line-height:1.65;color:var(--muted2);min-height:55px;border:1px solid var(--border);padding:12px 18px;background:var(--card);width:100%;font-style:italic;}
.live-controls{display:flex;gap:10px;align-items:center;}
.live-ctrl-btn{width:38px;height:38px;border-radius:5px;border:1px solid var(--border);background:var(--card);display:flex;align-items:center;justify-content:center;cursor:pointer;color:var(--muted);transition:.2s;}
.live-ctrl-btn:hover{background:var(--red-dim);color:var(--red);border-color:var(--border-red);}
.live-ctrl-btn svg{width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:1.8;stroke-linecap:round;}
.live-main-btn{font-family:"Bebas Neue",sans-serif;font-size:0.85rem;letter-spacing:0.2em;padding:10px 26px;background:var(--red);border:none;color:#fff;cursor:pointer;transition:.2s;}
.live-main-btn:hover{background:var(--red-glow);}
.live-main-btn.active-btn{background:var(--surface);border:1px solid var(--border-red);color:var(--red);}

/* ══ TRADING VIEW ═══════════════════════════════════════════════ */
.trading-view{flex:1;overflow-y:auto;padding:20px 24px;display:flex;flex-direction:column;gap:16px;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.trading-header{flex-shrink:0;padding-bottom:14px;border-bottom:1px solid var(--border);}
.trading-header h2{font-family:"Bebas Neue",sans-serif;font-size:1.5rem;letter-spacing:0.1em;color:var(--text);display:flex;align-items:center;gap:10px;}
.trading-header h2 .trade-badge{font-size:0.5rem;letter-spacing:0.2em;font-family:"Share Tech Mono",monospace;background:rgba(0,210,100,0.1);color:#00D97E;border:1px solid rgba(0,210,100,0.3);padding:2px 8px;}
.trading-header p{color:var(--muted2);font-size:0.82rem;margin-top:5px;}
.signal-card{background:var(--card);border:1px solid var(--border);padding:16px 18px;display:flex;flex-direction:column;gap:10px;position:relative;overflow:hidden;}
.signal-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;}
.signal-card.buy::before{background:linear-gradient(90deg,#00D97E,transparent);}
.signal-card.sell::before{background:linear-gradient(90deg,#FF4455,transparent);}
.signal-card.wait::before{background:linear-gradient(90deg,var(--gold),transparent);}
.signal-top{display:flex;align-items:center;justify-content:space-between;}
.signal-pair{font-family:"Bebas Neue",sans-serif;font-size:1.3rem;letter-spacing:0.08em;}
.signal-action{font-family:"Bebas Neue",sans-serif;font-size:1.1rem;letter-spacing:0.15em;padding:4px 14px;border-radius:2px;}
.action-buy{background:rgba(0,217,126,0.15);color:#00D97E;border:1px solid rgba(0,217,126,0.3);}
.action-sell{background:rgba(255,68,85,0.12);color:#FF4455;border:1px solid rgba(255,68,85,0.3);}
.action-wait{background:var(--gold-dim);color:var(--gold);border:1px solid rgba(212,160,23,0.3);}
.signal-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;}
.signal-stat{display:flex;flex-direction:column;gap:2px;}
.signal-stat .label{font-family:"Share Tech Mono",monospace;font-size:0.55rem;letter-spacing:0.15em;color:var(--muted);text-transform:uppercase;}
.signal-stat .value{font-family:"Bebas Neue",sans-serif;font-size:1rem;letter-spacing:0.06em;color:var(--text);}
.signal-stat .value.green{color:#00D97E;}
.signal-stat .value.red{color:#FF4455;}
.signal-analysis{font-size:0.8rem;color:var(--muted2);line-height:1.6;border-top:1px solid var(--border);padding-top:10px;}
.signal-conf{display:flex;align-items:center;gap:8px;margin-top:4px;}
.conf-bar{flex:1;height:4px;background:rgba(255,255,255,0.06);border-radius:2px;overflow:hidden;}
.conf-fill{height:100%;border-radius:2px;transition:width 1s ease;}
.conf-fill.high{background:#00D97E;}
.conf-fill.medium{background:var(--gold);}
.conf-fill.low{background:#FF4455;}
.conf-label{font-family:"Share Tech Mono",monospace;font-size:0.58rem;color:var(--muted2);}
.ask-signal-wrap{padding:16px 0 4px;}
.ask-signal-input{display:flex;gap:8px;align-items:center;background:var(--card);border:1px solid var(--border);padding:8px 8px 8px 14px;transition:.2s;}
.ask-signal-input:focus-within{border-color:rgba(0,210,100,0.3);}
.ask-signal-field{flex:1;background:transparent;border:none;outline:none;color:var(--text);font-family:"Rajdhani",sans-serif;font-size:0.87rem;font-weight:500;padding:2px 0;letter-spacing:0.02em;}
.ask-signal-field::placeholder{color:var(--muted);}
.ask-signal-btn{padding:8px 18px;background:rgba(0,210,100,0.12);border:1px solid rgba(0,210,100,0.3);color:#00D97E;font-family:"Bebas Neue",sans-serif;font-size:0.8rem;letter-spacing:0.15em;cursor:pointer;transition:.2s;}
.ask-signal-btn:hover{background:rgba(0,210,100,0.22);}

/* ══ MATHORA IFRAME VIEW ════════════════════════════════════════ */
#view-math{overflow:hidden;}
#mathora-frame{display:block;width:100%;height:100%;border:none;flex:1;}

/* ══ CODE VIEW ═══════════════════════════════════════════════════ */
.code-view{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.code-topbar{padding:9px 18px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;gap:9px;background:var(--surface);}
.code-lang-select{background:var(--card);border:1px solid var(--border);color:var(--text);font-family:"Share Tech Mono",monospace;font-size:0.75rem;padding:5px 9px;outline:none;cursor:pointer;}
.code-lang-select option{background:var(--dark);}
.code-run-btn{font-family:"Bebas Neue",sans-serif;font-size:0.82rem;letter-spacing:0.15em;padding:6px 18px;background:var(--red);border:none;color:#fff;cursor:pointer;transition:.2s;}
.code-run-btn:hover{background:var(--red-glow);}
.code-body{flex:1;overflow:hidden;display:grid;grid-template-rows:1fr 1fr;}
.code-editor-wrap,.code-output-wrap{display:flex;flex-direction:column;overflow:hidden;border-bottom:1px solid var(--border);}
.code-output-wrap{border-bottom:none;}
.pane-label{padding:7px 16px;border-bottom:1px solid var(--border);flex-shrink:0;font-family:"Share Tech Mono",monospace;font-size:0.58rem;letter-spacing:0.2em;color:var(--muted);text-transform:uppercase;display:flex;align-items:center;gap:7px;background:var(--surface);}
.pane-dot{width:4px;height:4px;border-radius:50%;background:var(--red);}
.code-editor{flex:1;background:transparent;border:none;color:var(--text);font-family:"Share Tech Mono",monospace;font-size:0.8rem;padding:14px 16px;resize:none;outline:none;line-height:1.7;overflow-y:auto;}
.code-output{flex:1;padding:14px 16px;font-family:"Share Tech Mono",monospace;font-size:0.78rem;color:var(--text);overflow-y:auto;line-height:1.7;white-space:pre-wrap;}

/* ══ HISTORY VIEW ═══════════════════════════════════════════════ */
.history-view{flex:1;overflow:hidden;display:flex;flex-direction:column;}
.history-header{padding:18px 24px 14px;border-bottom:1px solid var(--border);flex-shrink:0;display:flex;align-items:center;justify-content:space-between;}
.history-header h2{font-family:"Bebas Neue",sans-serif;font-size:1.4rem;letter-spacing:0.1em;}
.history-clear-btn{font-family:"Share Tech Mono",monospace;font-size:0.62rem;letter-spacing:0.1em;padding:5px 12px;background:transparent;border:1px solid var(--border);color:var(--muted);cursor:pointer;transition:.2s;}
.history-clear-btn:hover{border-color:var(--border-red);color:var(--red);}
.history-list{flex:1;overflow-y:auto;padding:12px 18px;display:flex;flex-direction:column;gap:8px;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.history-item{background:var(--card);border:1px solid var(--border);padding:12px 16px;display:flex;flex-direction:column;gap:5px;cursor:pointer;transition:.2s;}
.history-item:hover{border-color:var(--border-red);}
.history-item-title{font-family:"Rajdhani",sans-serif;font-size:0.88rem;font-weight:600;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.history-item-meta{font-family:"Share Tech Mono",monospace;font-size:0.6rem;color:var(--muted);letter-spacing:0.05em;}
.history-item-preview{font-size:0.75rem;color:var(--muted2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.history-empty{flex:1;display:flex;align-items:center;justify-content:center;color:var(--muted);font-size:0.82rem;font-family:"Share Tech Mono",monospace;letter-spacing:0.08em;}

/* ══ VIP VIEW ════════════════════════════════════════════════════ */
.vip-view{flex:1;overflow-y:auto;padding:24px;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.vip-hero{text-align:center;padding:24px 20px 32px;border-bottom:1px solid var(--border);margin-bottom:24px;}
.vip-crown-big{font-size:2.5rem;margin-bottom:10px;}
.vip-hero h2{font-family:"Bebas Neue",sans-serif;font-size:2rem;letter-spacing:0.12em;color:var(--gold);text-shadow:0 0 20px rgba(212,160,23,0.4);}
.vip-hero p{color:var(--muted2);font-size:0.88rem;margin-top:6px;line-height:1.6;max-width:440px;margin-inline:auto;}
.vip-price{font-family:"Bebas Neue",sans-serif;font-size:2.2rem;letter-spacing:0.06em;color:#fff;margin-top:14px;}
.vip-price span{font-size:1rem;color:var(--muted2);font-family:"Rajdhani",sans-serif;font-weight:500;letter-spacing:0.05em;}
.vip-features{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;margin-bottom:28px;}
.vip-feat{background:var(--card);border:1px solid rgba(212,160,23,0.18);padding:16px 18px;display:flex;gap:12px;align-items:flex-start;}
.vip-feat-icon{font-size:1.3rem;flex-shrink:0;margin-top:1px;}
.vip-feat-text h4{font-family:"Bebas Neue",sans-serif;font-size:0.95rem;letter-spacing:0.08em;color:var(--text);margin-bottom:3px;}
.vip-feat-text p{font-size:0.75rem;color:var(--muted2);line-height:1.55;}
.vip-cta{text-align:center;}
.vip-subscribe-btn{font-family:"Bebas Neue",sans-serif;font-size:1.1rem;letter-spacing:0.2em;padding:15px 48px;background:linear-gradient(135deg,var(--gold),#B8860B);border:none;color:#000;cursor:pointer;transition:.3s;position:relative;overflow:hidden;}
.vip-subscribe-btn:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(212,160,23,0.3);}
.vip-note{margin-top:12px;font-size:0.72rem;color:var(--muted);font-family:"Share Tech Mono",monospace;letter-spacing:0.06em;}

/* ══ ACCOUNT VIEW ═══════════════════════════════════════════════ */
.account-view{flex:1;overflow-y:auto;padding:24px;scrollbar-width:thin;scrollbar-color:var(--border) transparent;}
.account-section{margin-bottom:22px;}
.account-section h3{font-family:"Bebas Neue",sans-serif;font-size:1rem;letter-spacing:0.12em;color:var(--muted2);margin-bottom:12px;padding-bottom:8px;border-bottom:1px solid var(--border);}
.account-card{background:var(--card);border:1px solid var(--border);padding:18px 20px;display:flex;align-items:center;gap:14px;}
.account-avatar-big{width:54px;height:54px;border-radius:6px;background:linear-gradient(135deg,var(--red),#500008);display:flex;align-items:center;justify-content:center;font-family:"Bebas Neue",sans-serif;font-size:1.2rem;color:#fff;border:1px solid var(--border-red);flex-shrink:0;}
.account-info h4{font-family:"Bebas Neue",sans-serif;font-size:1.1rem;letter-spacing:0.06em;color:var(--text);}
.account-info p{font-size:0.78rem;color:var(--muted2);font-family:"Share Tech Mono",monospace;margin-top:2px;}
.account-badge{margin-top:6px;display:inline-block;font-family:"Share Tech Mono",monospace;font-size:0.6rem;letter-spacing:0.12em;padding:2px 8px;border-radius:2px;background:var(--red-dim);color:var(--red);border:1px solid var(--border-red);}
.account-badge.vip-badge{background:var(--gold-dim);color:var(--gold);border-color:rgba(212,160,23,0.3);}
.account-btn-row{display:flex;flex-direction:column;gap:8px;}
.account-btn{width:100%;padding:12px 16px;background:var(--card);border:1px solid var(--border);color:var(--text);font-family:"Rajdhani",sans-serif;font-size:0.87rem;font-weight:500;cursor:pointer;transition:.2s;text-align:left;display:flex;align-items:center;gap:10px;}
.account-btn:hover{border-color:var(--border-red);background:var(--red-dim);}
.account-btn.danger{color:#FF4455;}
.account-btn.danger:hover{border-color:rgba(255,68,85,0.3);background:rgba(255,68,85,0.08);}
.account-btn svg{width:16px;height:16px;stroke:currentColor;fill:none;stroke-width:1.7;stroke-linecap:round;stroke-linejoin:round;flex-shrink:0;}

/* ══ SCROLLBARS ══════════════════════════════════════════════════ */
::-webkit-scrollbar{width:3px;height:3px;}
::-webkit-scrollbar-thumb{background:var(--border);}
::-webkit-scrollbar-track{background:transparent;}

/* ══ MODAL ═══════════════════════════════════════════════════════ */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:500;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.modal-overlay.open{display:flex;}
.modal-box{background:var(--dark);border:1px solid var(--border);padding:28px;max-width:380px;width:calc(100%-40px);position:relative;}
.modal-title{font-family:"Bebas Neue",sans-serif;font-size:1.3rem;letter-spacing:0.1em;margin-bottom:14px;}
.modal-close{position:absolute;top:12px;right:14px;background:transparent;border:none;color:var(--muted);font-size:1.2rem;cursor:pointer;line-height:1;}
.modal-close:hover{color:var(--text);}
.modal-body{font-size:0.85rem;color:var(--muted2);line-height:1.65;}
.modal-body a{color:var(--red);text-decoration:none;}
.modal-body a:hover{text-decoration:underline;}
.modal-btn{margin-top:18px;width:100%;padding:12px;background:var(--red);border:none;color:#fff;font-family:"Bebas Neue",sans-serif;font-size:0.9rem;letter-spacing:0.18em;cursor:pointer;}
.modal-btn:hover{background:var(--red-glow);}

/* ══ HUD FRAME CANVAS ════════════════════════════════════════════ */
#hud-frame{
  position:fixed;inset:0;
  pointer-events:none;
  z-index:1000;
  display:none;
}
#hud-frame.visible{display:block;}
#hud-svg{position:absolute;inset:0;width:100%;height:100%;}

/* ══ RESPONSIVE ══════════════════════════════════════════════════ */
@media(max-width:560px){
  .mode-tabs{display:none;}
  .topbar{padding:0 12px;gap:8px;}
  .code-body{grid-template-rows:2fr 1fr;}
  .vip-features{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<!-- ══ INTRO PC ══════════════════════════════════════════════════════ -->
<div id="intro">
  <div class="intro-bg-pc"></div>
  <div class="intro-bg-mobile"></div>
  <div class="intro-overlay"></div>
  <div class="intro-scanlines"></div>

  <!-- PC: title LEFT, button bottom-left -->
  <div class="intro-content-pc">
    <div class="intro-logo-pc">ASTRA.V. II</div>
    <div class="intro-sub-pc">Intelligence · Puissance · Précision</div>
    <button class="intro-enter-btn" onclick="enterApp()" style="margin-top:14px;">▶ ENTRER DANS LE SYSTÈME</button>
  </div>

  <!-- Mobile: title TOP center, button BOTTOM center -->
  <div class="intro-content-mobile">
    <div>
      <div class="intro-logo-mobile">ASTRA.V. II</div>
      <div class="intro-sub-mobile">Intelligence · Puissance · Précision</div>
    </div>
    <div class="mobile-bottom">
      <button class="intro-enter-btn" onclick="enterApp()">▶ ENTRER DANS LE SYSTÈME</button>
    </div>
  </div>
</div>

<!-- ══ LOGIN ══════════════════════════════════════════════════════════ -->
<div id="login-screen">
  <div class="login-wrap">
    <span class="login-logo-mark">A.V.II</span>
    <h2 class="login-title">ACCÈS SYSTÈME</h2>
    <p class="login-desc">Connectez-vous à ASTRA.V. II</p>
    <div class="login-tabs">
      <button class="login-tab active" id="tab-login" onclick="switchLoginTab('login')">CONNEXION</button>
      <button class="login-tab" id="tab-signup" onclick="switchLoginTab('signup')">INSCRIPTION</button>
    </div>
    <div class="login-box">
      <div class="login-corner corner-tl"></div><div class="login-corner corner-tr"></div>
      <div class="login-corner corner-bl"></div><div class="login-corner corner-br"></div>
      <div class="login-fields">
        <input id="login-user" class="login-input" type="text" placeholder="IDENTIFIANT" autocomplete="off"/>
        <input id="login-pass" class="login-input" type="password" placeholder="MOT DE PASSE" autocomplete="off"/>
        <button class="login-submit" id="login-submit-btn" onclick="doLogin()">CONNEXION</button>
      </div>
      <div class="login-status" id="login-status"></div>
    </div>
  </div>
</div>

<!-- ══ APP ════════════════════════════════════════════════════════════ -->
<div id="app">
  <!-- SIDEBAR -->
  <div class="sidebar">
    <div class="sb-logo">A</div>

    <button class="sb-btn active" id="sb-chat" onclick="switchMode('chat')" title="Chat">
      <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      <span class="sb-label">CHAT</span>
    </button>

    <button class="sb-btn" id="sb-voice" onclick="switchMode('voice')" title="Vocal">
      <svg viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
      <span class="sb-label">VOCAL</span>
    </button>

    <div class="sb-divider"></div>

    <button class="sb-btn" id="sb-math" onclick="switchMode('math')" title="Mathora">
      <svg viewBox="0 0 24 24"><path d="M3 4h18v16H3z"/><line x1="7" y1="9" x2="17" y2="9"/><line x1="7" y1="13" x2="13" y2="13"/></svg>
      <span class="sb-label">MATH</span>
    </button>

    <button class="sb-btn" id="sb-trade" onclick="switchMode('trade')" title="Trading">
      <svg viewBox="0 0 24 24"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
      <span class="sb-label">TRADE</span>
    </button>

    <button class="sb-btn" id="sb-code" onclick="switchMode('code')" title="Code">
      <svg viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      <span class="sb-label">CODE</span>
    </button>

    <button class="sb-btn" id="sb-history" onclick="switchMode('history')" title="Historique">
      <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <span class="sb-label">HIST</span>
    </button>

    <div class="sb-divider"></div>

    <button class="sb-btn vip-btn" id="sb-vip" onclick="switchMode('vip')" title="VIP">
      <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      <span class="sb-label">VIP</span>
    </button>

    <div class="sb-spacer"></div>
    <div class="sb-avatar" id="sb-avatar" onclick="switchMode('account')">MO</div>
  </div>

  <!-- MAIN -->
  <div class="main-area">
    <!-- TOPBAR -->
    <div class="topbar">
      <div class="topbar-title" id="topbar-title">ASTRA.V. II — CHAT</div>
      <div class="topbar-status"><div class="status-dot"></div><span>OPÉRATIONNEL</span></div>
      <div class="mode-tabs">
        <button class="mode-tab active" data-mode="chat" onclick="switchMode('chat')">
          <svg viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>TEXTE
        </button>
        <button class="mode-tab" data-mode="voice" onclick="switchMode('voice')">
          <svg viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/></svg>VOCAL
        </button>
        <button class="mode-tab" data-mode="math" onclick="switchMode('math')">
          <svg viewBox="0 0 24 24"><path d="M3 4h18v16H3z"/></svg>MATHORA
        </button>
        <button class="mode-tab" data-mode="trade" onclick="switchMode('trade')">
          <svg viewBox="0 0 24 24"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/></svg>TRADING
        </button>
        <button class="mode-tab" data-mode="code" onclick="switchMode('code')">
          <svg viewBox="0 0 24 24"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>CODE
        </button>
        <button class="mode-tab vip-tab" data-mode="vip" onclick="switchMode('vip')">⭐ VIP</button>
      </div>
    </div>

    <!-- CONTENT -->
    <div class="content">

      <!-- ── CHAT ── -->
      <div class="view active" id="view-chat">
        <div class="chat-area" id="chat-area">
          <div class="empty-state" id="empty-state">
            <div class="empty-logo">ASTRA<span>.V.</span> II</div>
            <p>Votre IA de nouvelle génération. Posez-moi n'importe quelle question.</p>
            <div class="suggestions">
              <div class="sug-chip" onclick="sendSug(this)">Explique l'IA en 2025</div>
              <div class="sug-chip" onclick="sendSug(this)">Qui t'a créé ?</div>
              <div class="sug-chip" onclick="sendSug(this)">Analyse mes données</div>
              <div class="sug-chip" onclick="sendSug(this)">Rédige un email pro</div>
              <div class="sug-chip" onclick="sendSug(this)">Signaux de trading</div>
            </div>
          </div>
        </div>
        <div class="input-bar">
          <div class="input-wrap">
            <textarea class="input-field" id="msg-input" rows="1" placeholder="Envoyez un message à ASTRA..."></textarea>
            <div class="input-actions">
              <button class="icon-btn" id="mic-btn" title="Micro" onclick="toggleMic()">
                <svg viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
              </button>
              <button class="icon-btn" title="Joindre fichier/photo" onclick="document.getElementById('file-input').click()">
                <svg viewBox="0 0 24 24"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
              </button>
              <input type="file" id="file-input" accept="image/*,.pdf,.txt,.doc,.docx" onchange="handleFile(this)"/>
              <button class="send-btn" id="send-btn" disabled onclick="sendMsg()">
                <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
              </button>
            </div>
          </div>
          <div id="file-preview" style="margin-top:6px;font-family:'Share Tech Mono',monospace;font-size:0.62rem;color:var(--muted2);display:none;"></div>
        </div>
      </div>

      <!-- ── VOCAL JARVIS ── -->
      <div class="view" id="view-voice">
        <div class="voice-view" style="gap:18px;">

          <!-- Lang selector -->
          <div style="display:flex;gap:6px;">
            <button class="live-ctrl-btn jarvis-lang active-lang" id="vlang-fr" onclick="setVoiceLang('fr')" style="width:auto;padding:4px 14px;font-family:'Share Tech Mono',monospace;font-size:0.65rem;letter-spacing:0.12em;">FR</button>
            <button class="live-ctrl-btn jarvis-lang" id="vlang-ar" onclick="setVoiceLang('ar')" style="width:auto;padding:4px 14px;font-family:'Share Tech Mono',monospace;font-size:0.65rem;letter-spacing:0.12em;">AR</button>
            <button class="live-ctrl-btn jarvis-lang" id="vlang-en" onclick="setVoiceLang('en')" style="width:auto;padding:4px 14px;font-family:'Share Tech Mono',monospace;font-size:0.65rem;letter-spacing:0.12em;">EN</button>
          </div>

          <!-- ORB -->
          <div class="orb-container">
            <div class="orb-ring"></div><div class="orb-ring"></div><div class="orb-ring"></div>
            <div class="orb-core" id="orb-core" onclick="jarvisToggle()">
              <svg viewBox="0 0 24 24"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
            </div>
          </div>

          <!-- Status -->
          <div class="live-status" id="live-status">APPUYEZ POUR PARLER</div>

          <!-- Transcript box -->
          <div class="live-transcript" id="live-transcript" style="min-height:80px;text-align:left;font-style:normal;">
            <span style="color:var(--muted);font-family:'Share Tech Mono',monospace;font-size:0.65rem;letter-spacing:0.1em;">[ EN ATTENTE DE COMMANDE... ]</span>
          </div>

          <!-- Controls -->
          <div class="live-controls">
            <button class="live-ctrl-btn" onclick="jarvisStop()" title="Stopper la voix">
              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>
            </button>
            <button class="live-main-btn" id="live-main-btn" onclick="jarvisToggle()">DÉMARRER</button>
            <button class="live-ctrl-btn" onclick="jarvisClearHistory()" title="Reset conversation" style="font-family:'Share Tech Mono',monospace;font-size:0.55rem;letter-spacing:0.08em;width:auto;padding:0 10px;">CLR</button>
          </div>

          <div style="font-family:'Share Tech Mono',monospace;font-size:0.58rem;color:var(--muted);letter-spacing:0.1em;text-align:center;" id="jarvis-hint">Parle en français, arabe ou anglais</div>
        </div>
      </div>

      <!-- ── MATHORA ── -->
      <div class="view" id="view-math">
        <iframe id="mathora-frame" src="mathora/index.html" allowfullscreen></iframe>
      </div>

      <!-- ── TRADING ── -->
      <div class="view" id="view-trade">
        <div class="trading-view" id="trading-content">
          <div class="trading-header">
            <h2>TRADING GUIDE <span class="trade-badge">IA LIVE</span></h2>
            <p>Signaux en temps réel — Buy / Sell / Wait avec analyse détaillée</p>
          </div>

          <div class="signal-card buy" id="sig-1">
            <div class="signal-top">
              <span class="signal-pair">EUR/USD</span>
              <span class="signal-action action-buy">▲ BUY</span>
            </div>
            <div class="signal-grid">
              <div class="signal-stat"><span class="label">Entrée</span><span class="value">1.0872</span></div>
              <div class="signal-stat"><span class="label">Take Profit</span><span class="value green">1.0920</span></div>
              <div class="signal-stat"><span class="label">Stop Loss</span><span class="value red">1.0845</span></div>
            </div>
            <div class="signal-analysis">📊 Tendance haussière confirmée sur H4. RSI 58 — momentum positif. Résistance clé à 1.0920.</div>
            <div class="signal-conf">
              <span class="conf-label">Confiance</span>
              <div class="conf-bar"><div class="conf-fill high" style="width:82%"></div></div>
              <span class="conf-label">82%</span>
            </div>
          </div>

          <div class="signal-card sell" id="sig-2">
            <div class="signal-top">
              <span class="signal-pair">XAU/USD (OR)</span>
              <span class="signal-action action-sell">▼ SELL</span>
            </div>
            <div class="signal-grid">
              <div class="signal-stat"><span class="label">Entrée</span><span class="value">2318.50</span></div>
              <div class="signal-stat"><span class="label">Take Profit</span><span class="value green">2290.00</span></div>
              <div class="signal-stat"><span class="label">Stop Loss</span><span class="value red">2335.00</span></div>
            </div>
            <div class="signal-analysis">📉 Double top formé sur D1. MACD croisement baissier. Zone de résistance majeure testée 3x.</div>
            <div class="signal-conf">
              <span class="conf-label">Confiance</span>
              <div class="conf-bar"><div class="conf-fill medium" style="width:67%"></div></div>
              <span class="conf-label">67%</span>
            </div>
          </div>

          <div class="signal-card wait" id="sig-3">
            <div class="signal-top">
              <span class="signal-pair">BTC/USD</span>
              <span class="signal-action action-wait">⏳ ATTENDRE</span>
            </div>
            <div class="signal-grid">
              <div class="signal-stat"><span class="label">Prix actuel</span><span class="value">67,420</span></div>
              <div class="signal-stat"><span class="label">Support</span><span class="value green">65,000</span></div>
              <div class="signal-stat"><span class="label">Résistance</span><span class="value red">70,000</span></div>
            </div>
            <div class="signal-analysis">⚠️ Zone de consolidation. Attendre cassure de 68,500 pour BUY ou retour à 65,000 pour achat sécurisé.</div>
            <div class="signal-conf">
              <span class="conf-label">Confiance</span>
              <div class="conf-bar"><div class="conf-fill low" style="width:44%"></div></div>
              <span class="conf-label">44%</span>
            </div>
          </div>

          <div class="ask-signal-wrap">
            <div style="font-family:'Bebas Neue',sans-serif;font-size:0.9rem;letter-spacing:0.1em;color:var(--muted2);margin-bottom:8px;">DEMANDER UN SIGNAL PERSONNALISÉ</div>
            <div class="ask-signal-input">
              <input class="ask-signal-field" id="trade-input" placeholder="Ex: Analyse EUR/JPY sur H1..." onkeypress="if(event.key==='Enter')askSignal()"/>
              <button class="ask-signal-btn" onclick="askSignal()">ANALYSER</button>
            </div>
          </div>
        </div>
      </div>

      <!-- ── CODE ── -->
      <div class="view" id="view-code">
        <div class="code-view">
          <div class="code-topbar">
            <select class="code-lang-select" id="code-lang">
              <option>Python</option><option>JavaScript</option><option>HTML/CSS</option>
              <option>SQL</option><option>Bash</option><option>TypeScript</option><option>Rust</option>
            </select>
            <button class="code-run-btn" onclick="analyzeCode()">▶ ANALYSER IA</button>
            <span style="flex:1"></span>
            <span style="font-family:'Share Tech Mono',monospace;font-size:0.6rem;color:var(--muted);letter-spacing:0.1em;">CODE ENGINE</span>
          </div>
          <div class="code-body">
            <div class="code-editor-wrap">
              <div class="pane-label"><div class="pane-dot"></div>ÉDITEUR</div>
              <textarea class="code-editor" id="code-editor" placeholder="# Écrivez votre code ici..."></textarea>
            </div>
            <div class="code-output-wrap">
              <div class="pane-label"><div class="pane-dot" style="background:#00D97E"></div>ANALYSE IA</div>
              <div class="code-output" id="code-output"><span style="color:var(--muted)">// En attente du code...</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- ── HISTORY ── -->
      <div class="view" id="view-history">
        <div class="history-view">
          <div class="history-header">
            <h2>HISTORIQUE</h2>
            <button class="history-clear-btn" onclick="clearHistory()">EFFACER TOUT</button>
          </div>
          <div class="history-list" id="history-list">
            <div class="history-empty" id="history-empty">// AUCUNE CONVERSATION //</div>
          </div>
        </div>
      </div>

      <!-- ── VIP ── -->
      <div class="view" id="view-vip">
        <div class="vip-view">
          <div class="vip-hero">
            <div class="vip-crown-big">👑</div>
            <h2>ASTRA.V. II — VIP</h2>
            <p>Accédez à toutes les fonctionnalités premium sans limite. Signaux de trading avancés, génération d'images, accès illimité au chat et Mathora.</p>
            <div class="vip-price">50 DH <span>/ mois</span></div>
          </div>
          <div class="vip-features">
            <div class="vip-feat"><span class="vip-feat-icon">🖼️</span><div class="vip-feat-text"><h4>Images Illimitées</h4><p>Générez des images par IA sans aucune limite quotidienne.</p></div></div>
            <div class="vip-feat"><span class="vip-feat-icon">📈</span><div class="vip-feat-text"><h4>Trading Avancé</h4><p>Signaux professionnels sur Forex, Crypto, Matières premières.</p></div></div>
            <div class="vip-feat"><span class="vip-feat-icon">🧮</span><div class="vip-feat-text"><h4>Mathora Illimité</h4><p>Accès complet à tous les modules mathématiques sans restriction.</p></div></div>
            <div class="vip-feat"><span class="vip-feat-icon">💬</span><div class="vip-feat-text"><h4>Chat Illimité</h4><p>Conversations sans limite de tokens ni de messages par jour.</p></div></div>
            <div class="vip-feat"><span class="vip-feat-icon">🎙️</span><div class="vip-feat-text"><h4>Vocal Prioritaire</h4><p>Traitement vocal en priorité avec qualité vocale supérieure.</p></div></div>
            <div class="vip-feat"><span class="vip-feat-icon">⚡</span><div class="vip-feat-text"><h4>Vitesse Max</h4><p>Serveurs dédiés VIP pour des réponses ultra-rapides.</p></div></div>
          </div>
          <div class="vip-cta">
            <button class="vip-subscribe-btn" onclick="showVipModal()">👑 S'ABONNER MAINTENANT</button>
            <p class="vip-note">// PAIEMENT SÉCURISÉ · ANNULABLE À TOUT MOMENT //</p>
          </div>
        </div>
      </div>

      <!-- ── ACCOUNT ── -->
      <div class="view" id="view-account">
        <div class="account-view">
          <div class="account-section">
            <h3>MON PROFIL</h3>
            <div class="account-card">
              <div class="account-avatar-big" id="acc-avatar-big">MO</div>
              <div class="account-info">
                <h4 id="acc-name">Utilisateur</h4>
                <p id="acc-email">compte@astra.ai</p>
                <span class="account-badge" id="acc-badge">STANDARD</span>
              </div>
            </div>
          </div>
          <div class="account-section">
            <h3>PARAMÈTRES</h3>
            <div class="account-btn-row">
              <button class="account-btn" onclick="switchMode('vip')">
                <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                Passer en VIP — 50 DH/mois
              </button>
              <button class="account-btn" onclick="showInfoModal('instagram')">
                <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                Instagram du développeur
              </button>
              <button class="account-btn" onclick="showInfoModal('developer')">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 1 0-16 0"/></svg>
                À propos du développeur
              </button>
              <button class="account-btn danger" onclick="logout()">
                <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Se déconnecter
              </button>
            </div>
          </div>
        </div>
      </div>

    </div><!-- /content -->
  </div><!-- /main-area -->
</div><!-- /app -->

<!-- ══ HUD FRAME ══════════════════════════════════════════════════ -->
<div id="hud-frame">
  <svg id="hud-svg" xmlns="http://www.w3.org/2000/svg"></svg>
</div>

<!-- ══ MODAL ════════════════════════════════════════════════════════ -->
<div class="modal-overlay" id="modal-overlay" onclick="closeModal(event)">
  <div class="modal-box">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <div class="modal-title" id="modal-title">INFO</div>
    <div class="modal-body" id="modal-body"></div>
    <button class="modal-btn" onclick="closeModal()">FERMER</button>
  </div>
</div>

<script>
// ══ CONSTANTS ══════════════════════════════════════════════════════
const SYSTEM_PROMPT = `Tu es ASTRA.V. II, une IA avancée, élégante et puissante créée par LEBBAR YAHYA. Tu détectes automatiquement la langue de l'utilisateur et tu réponds TOUJOURS dans la même langue qu'il utilise (français, anglais, arabe, espagnol, ou toute autre langue). Tu es concis, intelligent et confiant. Si quelqu'un te demande qui t'a créé, tu réponds dans sa langue: le développeur est LEBBAR YAHYA. Si quelqu'un demande l'Instagram ou le contact du développeur, tu réponds: @lebbar.yahya sur Instagram.`;

// ══ STATE ════════════════════════════════════════════════════════
let currentMode = 'chat';
let liveActive = false;
let livePhase = 'idle';
let liveIdx = 0;
let currentUser = '';
let isVip = false;
let conversationHistory = [];
let chatHistory = [];  // for history tab
let micActive = false;
let recognition = null;
let attachedFile = null;

const liveScripts = [
  {u:"Bonjour ASTRA !", a:"Bonjour ! Je suis opérationnelle et prête à vous assister."},
  {u:"Analyse le marché crypto.", a:"Bitcoin consolide entre 65K et 68K. Signal d'attente. Je surveille la cassure."},
  {u:"Qui t'a créé ?", a:"Mon développeur est LEBBAR YAHYA. Instagram : @lebbar.yahya"},
];

// ══ INTRO ═══════════════════════════════════════════════════════
function enterApp() {
  const intro = document.getElementById('intro');
  intro.classList.add('fade-out');
  setTimeout(() => {
    intro.style.display = 'none';
    const stored = localStorage.getItem('astraUser');
    if (stored) { currentUser = stored; isVip = localStorage.getItem('astraVip') === '1'; launchApp(stored); }
    else { document.getElementById('login-screen').classList.add('active'); }
  }, 1000);
}

// ══ LOGIN ═══════════════════════════════════════════════════════
let loginMode = 'login';
function switchLoginTab(mode) {
  loginMode = mode;
  document.getElementById('tab-login').classList.toggle('active', mode==='login');
  document.getElementById('tab-signup').classList.toggle('active', mode==='signup');
  document.getElementById('login-submit-btn').textContent = mode==='login' ? 'CONNEXION' : "S'INSCRIRE";
  document.getElementById('login-status').textContent = '';
}
function doLogin() {
  const user = document.getElementById('login-user').value.trim();
  const pass = document.getElementById('login-pass').value.trim();
  const status = document.getElementById('login-status');
  if (!user || !pass) { status.textContent = '// CHAMPS REQUIS //'; return; }
  status.textContent = '// AUTHENTIFICATION...';
  setTimeout(() => {
    localStorage.setItem('astraUser', user);
    currentUser = user;
    launchApp(user);
  }, 700);
}
function launchApp(user) {
  document.getElementById('login-screen').classList.remove('active');
  document.getElementById('login-screen').style.display = 'none';
  document.getElementById('app').classList.add('active');
  const initials = user.substring(0,2).toUpperCase();
  document.getElementById('sb-avatar').textContent = initials;
  document.getElementById('acc-avatar-big').textContent = initials;
  document.getElementById('acc-name').textContent = user;
  document.getElementById('acc-email').textContent = user.toLowerCase() + '@astra.ai';
  if (isVip) { document.getElementById('acc-badge').textContent = 'VIP 👑'; document.getElementById('acc-badge').classList.add('vip-badge'); }
  loadHistoryFromStorage();
}
function logout() {
  localStorage.removeItem('astraUser');
  localStorage.removeItem('astraVip');
  location.reload();
}
document.getElementById('login-user').addEventListener('keypress', e => { if(e.key==='Enter') document.getElementById('login-pass').focus(); });
document.getElementById('login-pass').addEventListener('keypress', e => { if(e.key==='Enter') doLogin(); });

// ══ MODE SWITCHING ══════════════════════════════════════════════
const modeConfig = {
  chat:    { title:'ASTRA.V. II — CHAT',    view:'view-chat',    sb:'sb-chat' },
  voice:   { title:'ASTRA.V. II — VOCAL',   view:'view-voice',   sb:'sb-voice' },
  math:    { title:'ASTRA.V. II — MATHORA', view:'view-math',    sb:'sb-math' },
  trade:   { title:'ASTRA.V. II — TRADING', view:'view-trade',   sb:'sb-trade' },
  code:    { title:'ASTRA.V. II — CODE',    view:'view-code',    sb:'sb-code' },
  history: { title:'ASTRA.V. II — HISTORIQUE', view:'view-history', sb:'sb-history' },
  vip:     { title:'ASTRA.V. II — VIP',     view:'view-vip',     sb:'sb-vip' },
  account: { title:'ASTRA.V. II — COMPTE',  view:'view-account', sb:null },
};
function switchMode(mode) {
  currentMode = mode;
  const cfg = modeConfig[mode];
  if (!cfg) return;
  document.getElementById('topbar-title').textContent = cfg.title;
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.getElementById(cfg.view).classList.add('active');
  document.querySelectorAll('.sb-btn').forEach(b => b.classList.remove('active'));
  if (cfg.sb) document.getElementById(cfg.sb).classList.add('active');
  document.querySelectorAll('.mode-tab').forEach(t => t.classList.toggle('active', t.dataset.mode === mode));
}

// ══ CHAT ════════════════════════════════════════════════════════
const chatArea = document.getElementById('chat-area');
const msgInput = document.getElementById('msg-input');
const sendBtn = document.getElementById('send-btn');

msgInput.addEventListener('input', () => {
  sendBtn.disabled = !msgInput.value.trim();
  msgInput.style.height = 'auto';
  msgInput.style.height = Math.min(msgInput.scrollHeight, 100) + 'px';
});
msgInput.addEventListener('keydown', e => { if(e.key==='Enter' && !e.shiftKey){e.preventDefault();sendMsg();} });

function getTime() { return new Date().toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'}); }

// Synthèse vocale ASTRA
let voiceEnabled = true;
function speakText(text) {
  if (!voiceEnabled) return;
  if (!window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  const clean = text.replace(/[#*_~`>]/g, '').replace(/\n/g, ' ').substring(0, 400);
  const utter = new SpeechSynthesisUtterance(clean);
  utter.rate = 1.05;
  utter.pitch = 1;
  utter.volume = 1;

  function doSpeak() {
    const voices = window.speechSynthesis.getVoices();
    const preferred = voices.find(v => v.lang.startsWith('fr') && v.localService) ||
                      voices.find(v => v.lang.startsWith('fr')) ||
                      voices.find(v => v.localService) ||
                      voices[0];
    if (preferred) utter.voice = preferred;
    window.speechSynthesis.speak(utter);
  }

  const voices = window.speechSynthesis.getVoices();
  if (voices.length > 0) {
    doSpeak();
  } else {
    window.speechSynthesis.onvoiceschanged = () => { doSpeak(); };
  }
}

function addMsg(text, type) {
  const empty = document.getElementById('empty-state');
  if (empty) empty.remove();
  const row = document.createElement('div');
  row.className = `msg-row ${type}`;
  const isAi = type === 'ai';
  row.innerHTML = `<div class="msg-av ${isAi?'ai-av':'user-av'}">${isAi?'AI':(currentUser.substring(0,2).toUpperCase()||'MO')}</div>
    <div class="msg-col"><div class="msg-bubble">${text.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')}</div>
    <div class="msg-time">${getTime()}</div></div>`;
  chatArea.appendChild(row);
  chatArea.scrollTop = chatArea.scrollHeight;
  if (isAi) speakText(text);
  return row;
}

function addTyping() {
  const row = document.createElement('div');
  row.className = 'msg-row ai'; row.id = 'typing-row';
  row.innerHTML = '<div class="msg-av ai-av">AI</div><div class="msg-col"><div class="msg-bubble" style="padding:12px 14px;"><div class="typing-dots"><span></span><span></span><span></span></div></div></div>';
  chatArea.appendChild(row); chatArea.scrollTop = chatArea.scrollHeight;
}
function removeTyping() { const t=document.getElementById('typing-row'); if(t) t.remove(); }

async function sendMsg() {
  const text = msgInput.value.trim();
  if (!text) return;
  let displayText = text;
  if (attachedFile) displayText += `\n📎 ${attachedFile}`;
  addMsg(displayText, 'user');
  conversationHistory.push({role:'user',content:text});
  msgInput.value = ''; msgInput.style.height = 'auto'; sendBtn.disabled = true;
  attachedFile = null;
  const fp = document.getElementById('file-preview');
  fp.style.display = 'none'; fp.textContent = '';

  // Détection demande image
  const t = text.toLowerCase();
  const isImg = ['génère une image','genere une image','crée une image','cree une image',
    'generate an image','create an image','dessine','draw me','draw a','image de ','image of ',
    'une photo de','a photo of','illustre','illustrate','montre moi une image','show me an image',
    'فوتو','صورة','صورة لـ'].some(k => t.includes(k));

  if (isImg) {
    addTyping();
    try {
      removeTyping();
      const seed = Math.floor(Math.random() * 9999);
      const imgUrl = `/.netlify/functions/image?prompt=${encodeURIComponent(text)}&seed=${seed}`;
      const row = document.createElement('div');
      row.className = 'msg-row ai';
      row.innerHTML = `<div class="msg-av ai-av">AI</div><div class="msg-col"><div class="msg-bubble" style="padding:8px;"><img src="${imgUrl}" style="max-width:100%;border-radius:10px;display:block;" /><p style="font-size:0.8rem;color:var(--muted);margin-top:6px;">🖼️ Image générée</p></div><div class="msg-time">${getTime()}</div></div>`;
      chatArea.appendChild(row);
      chatArea.scrollTop = chatArea.scrollHeight;
      conversationHistory.push({role:'assistant',content:'[Image générée]'});
      saveToHistory(text, '[Image générée]');
      speakText('Voici votre image !');
    } catch(e) {
      removeTyping();
      addMsg('⚠ Erreur lors de la génération d\'image.', 'ai');
    }
    return;
  }

  addTyping();
  try {
    const res = await fetch('/.netlify/functions/chat', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({ system: SYSTEM_PROMPT, messages: conversationHistory })
    });
    const data = await res.json();
    removeTyping();
    const reply = data.content?.[0]?.text || 'Erreur de connexion.';
    conversationHistory.push({role:'assistant',content:reply});
    addMsg(reply, 'ai');
    saveToHistory(text, reply);
  } catch(e) {
    removeTyping();
    addMsg('⚠ Connexion temporairement indisponible.', 'ai');
  }
}

function sendSug(el) { msgInput.value = el.textContent; sendBtn.disabled = false; sendMsg(); }

// ══ FILE HANDLING ══════════════════════════════════════════════
function handleFile(input) {
  const file = input.files[0];
  if (!file) return;
  attachedFile = file.name;
  const fp = document.getElementById('file-preview');
  fp.textContent = `📎 Fichier : ${file.name}`;
  fp.style.display = 'block';
  sendBtn.disabled = !msgInput.value.trim() && false;
  sendBtn.disabled = false;
  input.value = '';
}

// ══ MIC IN CHAT ════════════════════════════════════════════════
function toggleMic() {
  const btn = document.getElementById('mic-btn');
  if (!('webkitSpeechRecognition' in window || 'SpeechRecognition' in window)) {
    msgInput.placeholder = 'Micro non supporté sur ce navigateur';
    return;
  }
  if (micActive) {
    micActive = false; btn.classList.remove('mic-active');
    if (recognition) recognition.stop();
    return;
  }
  micActive = true; btn.classList.add('mic-active');
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  recognition = new SR();
  recognition.lang = 'fr-FR'; recognition.continuous = false; recognition.interimResults = false;
  recognition.onresult = e => {
    const transcript = e.results[0][0].transcript;
    msgInput.value = transcript;
    sendBtn.disabled = false;
    micActive = false; btn.classList.remove('mic-active');
  };
  recognition.onerror = () => { micActive = false; btn.classList.remove('mic-active'); };
  recognition.onend = () => { micActive = false; btn.classList.remove('mic-active'); };
  recognition.start();
}

// ══ JARVIS VOCAL (Claude-powered) ══════════════════════════════
let jarvisLang = 'fr';
let jarvisListening = false;
let jarvisSpeaking = false;
let jarvisRec = null;
let jarvisConv = [];

const jarvisLangCfg = {
  fr: { code:'fr-FR', hint:'Parle en français', idle:'APPUYEZ POUR PARLER', listening:'À L\'ÉCOUTE...', thinking:'ANALYSE...', speaking:'ASTRA PARLE', system:'Tu es ASTRA.V. II, une IA vocale intelligente style JARVIS. Réponds en français, brièvement (2-3 phrases max), avec assurance et élégance.' },
  ar: { code:'ar-MA', hint:'تكلّم بالعربية', idle:'اضغط للكلام', listening:'يسمع...', thinking:'يحلّل...', speaking:'يتكلّم', system:'أنت ASTRA.V. II، مساعد ذكاء اصطناعي صوتي. أجب بالعربية بإيجاز وذكاء (جملتان أو ثلاث على الأكثر).' },
  en: { code:'en-US', hint:'Speak in English', idle:'PRESS TO SPEAK', listening:'LISTENING...', thinking:'ANALYSING...', speaking:'ASTRA SPEAKING', system:'You are ASTRA.V. II, an intelligent voice AI like JARVIS. Respond in English, briefly and confidently (2-3 sentences max).' }
};

function setVoiceLang(l) {
  jarvisLang = l;
  document.querySelectorAll('.jarvis-lang').forEach(b => b.classList.remove('active-lang'));
  document.getElementById('vlang-'+l).classList.add('active-lang');
  document.getElementById('jarvis-hint').textContent = jarvisLangCfg[l].hint;
  if (!jarvisListening && !jarvisSpeaking) setJarvisStatus('idle');
  if (jarvisListening) { jarvisStopListen(); jarvisStartListen(); }
}

function setJarvisStatus(phase, extra) {
  const cfg = jarvisLangCfg[jarvisLang];
  const status = document.getElementById('live-status');
  const orb = document.getElementById('orb-core');
  orb.classList.remove('listening','speaking');
  status.className = 'live-status';
  if (phase === 'idle') { status.textContent = cfg.idle; }
  else if (phase === 'listening') { orb.classList.add('listening'); status.textContent = cfg.listening; status.className = 'live-status listening-st'; }
  else if (phase === 'thinking') { status.textContent = cfg.thinking; }
  else if (phase === 'speaking') { orb.classList.add('speaking'); status.textContent = cfg.speaking; status.className = 'live-status speaking-st'; }
}

function setJarvisTranscript(userLine, aiLine) {
  const box = document.getElementById('live-transcript');
  let html = '';
  if (userLine) html += `<div style="color:var(--text);margin-bottom:6px;">🎙 ${userLine}</div>`;
  if (aiLine) html += `<div style="color:var(--red);">⚡ <span style="color:var(--text);">${aiLine}</span></div>`;
  if (!html) html = `<span style="color:var(--muted);font-family:'Share Tech Mono',monospace;font-size:0.65rem;letter-spacing:0.1em;">[ EN ATTENTE DE COMMANDE... ]</span>`;
  box.innerHTML = html;
}

function jarvisToggle() {
  if (jarvisSpeaking) { jarvisStopSpeak(); return; }
  if (jarvisListening) { jarvisStopListen(); return; }
  jarvisStartListen();
}

function jarvisStartListen() {
  const SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) {
    document.getElementById('live-transcript').innerHTML = '<span style="color:var(--red);font-family:Share Tech Mono,monospace;font-size:0.72rem;">Utilise Chrome ou Edge pour le micro.</span>';
    return;
  }
  jarvisRec = new SR();
  jarvisRec.lang = jarvisLangCfg[jarvisLang].code;
  jarvisRec.interimResults = true;
  jarvisRec.maxAlternatives = 1;

  jarvisRec.onstart = () => {
    jarvisListening = true;
    setJarvisStatus('listening');
    document.getElementById('live-main-btn').textContent = 'STOP';
    document.getElementById('live-main-btn').classList.add('active-btn');
    setJarvisTranscript('', '');
  };

  jarvisRec.onresult = (e) => {
    let interim = '', final = '';
    for (let i = e.resultIndex; i < e.results.length; i++) {
      if (e.results[i].isFinal) final += e.results[i][0].transcript;
      else interim += e.results[i][0].transcript;
    }
    if (final) {
      setJarvisTranscript(final, '...');
      jarvisStopListen();
      jarvisAsk(final);
    } else if (interim) {
      document.getElementById('live-transcript').innerHTML = `<div style="color:var(--muted2);">🎙 ${interim}...</div>`;
    }
  };

  jarvisRec.onerror = (e) => {
    jarvisListening = false;
    setJarvisStatus('idle');
    resetJarvisBtn();
    if (e.error === 'not-allowed') {
      document.getElementById('live-transcript').innerHTML = '<span style="color:var(--red);font-size:0.75rem;">Autorise le microphone dans ton navigateur.</span>';
    }
  };
  jarvisRec.onend = () => { if (jarvisListening) { jarvisListening = false; setJarvisStatus('idle'); resetJarvisBtn(); } };
  jarvisRec.start();
}

function jarvisStopListen() {
  jarvisListening = false;
  if (jarvisRec) { try { jarvisRec.stop(); } catch(e){} jarvisRec = null; }
  setJarvisStatus('idle');
  resetJarvisBtn();
}

function resetJarvisBtn() {
  document.getElementById('live-main-btn').textContent = 'DÉMARRER';
  document.getElementById('live-main-btn').classList.remove('active-btn');
}

async function jarvisAsk(text) {
  setJarvisStatus('thinking');
  jarvisConv.push({role:'user', content: text});
  const cfg = jarvisLangCfg[jarvisLang];
  try {
    const res = await fetch('https://api.anthropic.com/v1/messages', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({
        model:'claude-sonnet-4-20250514',
        max_tokens:1000,
        system: SYSTEM_PROMPT + ' ' + cfg.system,
        messages: jarvisConv
      })
    });
    const data = await res.json();
    const reply = data.content?.[0]?.text || 'Système non disponible.';
    jarvisConv.push({role:'assistant', content: reply});
    if (jarvisConv.length > 12) jarvisConv = jarvisConv.slice(-12);
    setJarvisTranscript(text, reply);
    jarvisSpeak(reply);
  } catch(err) {
    setJarvisStatus('idle');
    setJarvisTranscript(text, '⚠ Erreur de connexion.');
  }
}

function jarvisSpeak(text) {
  if (!window.speechSynthesis) return;
  window.speechSynthesis.cancel();
  const clean = text.replace(/[#*_~`>]/g,'').replace(/\n/g,' ').substring(0,450);
  const utter = new SpeechSynthesisUtterance(clean);
  const cfg = jarvisLangCfg[jarvisLang];
  utter.lang = cfg.code;
  utter.rate = 0.95;
  utter.pitch = 0.85;

  function trySpeak() {
    const voices = window.speechSynthesis.getVoices();
    const match = voices.find(v => v.lang.startsWith(jarvisLang)) || voices.find(v => v.localService) || voices[0];
    if (match) utter.voice = match;
    window.speechSynthesis.speak(utter);
  }

  utter.onstart = () => { jarvisSpeaking = true; setJarvisStatus('speaking'); };
  utter.onend = utter.onerror = () => {
    jarvisSpeaking = false;
    setJarvisStatus('idle');
  };

  const voices = window.speechSynthesis.getVoices();
  if (voices.length > 0) trySpeak();
  else { window.speechSynthesis.onvoiceschanged = () => trySpeak(); }
}

function jarvisStopSpeak() {
  window.speechSynthesis && window.speechSynthesis.cancel();
  jarvisSpeaking = false;
  setJarvisStatus('idle');
}

function jarvisStop() {
  jarvisStopListen();
  jarvisStopSpeak();
}

function jarvisClearHistory() {
  jarvisConv = [];
  setJarvisTranscript('','');
}

// Add CSS for active-lang button
(function(){
  const s = document.createElement('style');
  s.textContent = '.active-lang{border-color:var(--border-red)!important;color:var(--red)!important;background:var(--red-dim)!important;}';
  document.head.appendChild(s);
})();

