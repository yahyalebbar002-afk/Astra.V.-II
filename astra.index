// ══ HUD FRAME ANIMATION ════════════════════════════════════════
(function(){
  const NS = 'http://www.w3.org/2000/svg';
  const RED = '#FF1525';
  const RED_DIM = 'rgba(200,0,10,0.18)';
  const ARM = 56;     // corner arm length
  const PAD = 10;     // inset from edge
  const SPARK_LEN = 60;

  let W = 0, H = 0;
  const svg = document.getElementById('hud-svg');

  function mkEl(tag, attrs){
    const el = document.createElementNS(NS, tag);
    for(const [k,v] of Object.entries(attrs)) el.setAttribute(k,v);
    return el;
  }

  // Build static SVG structure
  function build(){
    W = window.innerWidth;
    H = window.innerHeight;
    svg.setAttribute('viewBox', '0 0 '+W+' '+H);
    svg.innerHTML = '';

    const defs = mkEl('defs',{});

    // Glow filter
    const filt = mkEl('filter',{id:'hglow',x:'-50%',y:'-50%',width:'200%',height:'200%'});
    const fe1 = mkEl('feGaussianBlur',{in:'SourceGraphic',stdDeviation:'3',result:'blur'});
    const fe2 = mkEl('feMerge',{});
    const m1 = mkEl('feMergeNode',{in:'blur'});
    const m2 = mkEl('feMergeNode',{in:'SourceGraphic'});
    fe2.appendChild(m1); fe2.appendChild(m2);
    filt.appendChild(fe1); filt.appendChild(fe2);
    defs.appendChild(filt);

    // Gradient for transfer line
    const grad = mkEl('linearGradient',{id:'sparkGrad',x1:'0%',y1:'0%',x2:'100%',y2:'0%'});
    const s0 = mkEl('stop',{offset:'0%','stop-color':RED,'stop-opacity':'0'});
    const s1 = mkEl('stop',{offset:'50%','stop-color':RED,'stop-opacity':'1'});
    const s2 = mkEl('stop',{offset:'100%','stop-color':RED,'stop-opacity':'0'});
    grad.appendChild(s0); grad.appendChild(s1); grad.appendChild(s2);
    defs.appendChild(grad);

    const gradV = mkEl('linearGradient',{id:'sparkGradV',x1:'0%',y1:'0%',x2:'0%',y2:'100%'});
    const v0 = mkEl('stop',{offset:'0%','stop-color':RED,'stop-opacity':'0'});
    const v1 = mkEl('stop',{offset:'50%','stop-color':RED,'stop-opacity':'1'});
    const v2 = mkEl('stop',{offset:'100%','stop-color':RED,'stop-opacity':'0'});
    gradV.appendChild(v0); gradV.appendChild(v1); gradV.appendChild(v2);
    defs.appendChild(gradV);

    svg.appendChild(defs);

    // ── CORNER L-SHAPES ──────────────────────────────────────
    const corners = [
      // [x,y, hx1,hy1,hx2,hy2,  vx1,vy1,vx2,vy2,  dotX,dotY]
      [PAD, PAD,
       PAD,PAD, PAD+ARM,PAD,          // H arm →
       PAD,PAD, PAD,PAD+ARM,           // V arm ↓
       PAD,PAD],
      [W-PAD, PAD,
       W-PAD-ARM,PAD, W-PAD,PAD,       // H arm ←
       W-PAD,PAD, W-PAD,PAD+ARM,       // V arm ↓
       W-PAD,PAD],
      [PAD, H-PAD,
       PAD,H-PAD, PAD+ARM,H-PAD,       // H arm →
       PAD,H-PAD-ARM, PAD,H-PAD,       // V arm ↑
       PAD,H-PAD],
      [W-PAD, H-PAD,
       W-PAD-ARM,H-PAD, W-PAD,H-PAD,  // H arm ←
       W-PAD,H-PAD-ARM, W-PAD,H-PAD,  // V arm ↑
       W-PAD,H-PAD],
    ];

    corners.forEach(([,, hx1,hy1,hx2,hy2, vx1,vy1,vx2,vy2, dx,dy]) => {
      // Dim base lines
      svg.appendChild(mkEl('line',{x1:hx1,y1:hy1,x2:hx2,y2:hy2,stroke:RED_DIM,'stroke-width':'1.5'}));
      svg.appendChild(mkEl('line',{x1:vx1,y1:vy1,x2:vx2,y2:vy2,stroke:RED_DIM,'stroke-width':'1.5'}));
      // Bright overlay
      svg.appendChild(mkEl('line',{x1:hx1,y1:hy1,x2:hx2,y2:hy2,stroke:RED,'stroke-width':'1.5',filter:'url(#hglow)'}));
      svg.appendChild(mkEl('line',{x1:vx1,y1:vy1,x2:vx2,y2:vy2,stroke:RED,'stroke-width':'1.5',filter:'url(#hglow)'}));
      // Corner dot
      const dot = mkEl('circle',{cx:dx,cy:dy,r:'3.5',fill:RED,filter:'url(#hglow)'});
      svg.appendChild(dot);
      // Animate dot pulse
      const anim = mkEl('animate',{attributeName:'r',values:'3.5;5.5;3.5',dur:'2s',repeatCount:'indefinite'});
      dot.appendChild(anim);
      const animOp = mkEl('animate',{attributeName:'opacity',values:'1;0.3;1',dur:'2s',repeatCount:'indefinite'});
      dot.appendChild(animOp);
    });

    // ── EDGE RAILS (dim lines connecting corners) ─────────
    // top, bottom, left, right
    const rails = [
      [PAD+ARM, PAD,    W-PAD-ARM, PAD],    // top
      [PAD+ARM, H-PAD,  W-PAD-ARM, H-PAD],  // bottom
      [PAD, PAD+ARM,    PAD, H-PAD-ARM],     // left
      [W-PAD, PAD+ARM,  W-PAD, H-PAD-ARM],  // right
    ];
    rails.forEach(([x1,y1,x2,y2]) => {
      svg.appendChild(mkEl('line',{x1,y1,x2,y2,stroke:RED_DIM,'stroke-width':'1'}));
    });

    // ── SPARK PARTICLES (travel along edges) ─────────────
    // Each spark: line element animated along the perimeter
    // We use animateMotion on a path for smooth corner-to-corner travel

    // Full perimeter path (clockwise from TL)
    const perimPath = `M ${PAD} ${PAD+ARM} L ${PAD} ${PAD} L ${PAD+ARM} ${PAD} L ${W-PAD-ARM} ${PAD} L ${W-PAD} ${PAD} L ${W-PAD} ${PAD+ARM} L ${W-PAD} ${H-PAD-ARM} L ${W-PAD} ${H-PAD} L ${W-PAD-ARM} ${H-PAD} L ${PAD+ARM} ${H-PAD} L ${PAD} ${H-PAD} L ${PAD} ${H-PAD-ARM} Z`;

    function makeSpark(delay, color, width, blur){
      const g = mkEl('g',{});
      const line = mkEl('line',{x1:0,y1:0,x2:0,y2:0,stroke:color,'stroke-width':String(width),'stroke-linecap':'round'});
      if(blur) line.setAttribute('filter','url(#hglow)');

      const pathEl = mkEl('path',{d:perimPath,fill:'none',stroke:'none'});
      svg.appendChild(pathEl);
      const pathId = 'sp'+Math.random().toString(36).slice(2);
      pathEl.setAttribute('id',pathId);

      // Use a rect as moving dot instead of animateMotion on line
      const dot = mkEl('circle',{r:String(width*1.2),fill:color});
      if(blur) dot.setAttribute('filter','url(#hglow)');
      const mot = mkEl('animateMotion',{
        dur:'6s',
        repeatCount:'indefinite',
        begin: delay+'s',
        rotate:'auto'
      });
      const mpath = mkEl('mpath',{});
      mpath.setAttributeNS('http://www.w3.org/1999/xlink','href','#'+pathId);
      mot.appendChild(mpath);
      dot.appendChild(mot);
      g.appendChild(dot);
      return g;
    }

    // 2 sparks going clockwise, offset by half
    svg.appendChild(makeSpark(0,   RED, 3, true));
    svg.appendChild(makeSpark(3,   RED, 2, true));
    // 1 spark in reverse — counter-clockwise using reversed path
    const perimPathRev = `M ${PAD} ${H-PAD-ARM} L ${PAD} ${H-PAD} L ${PAD+ARM} ${H-PAD} L ${W-PAD-ARM} ${H-PAD} L ${W-PAD} ${H-PAD} L ${W-PAD} ${H-PAD-ARM} L ${W-PAD} ${PAD+ARM} L ${W-PAD} ${PAD} L ${W-PAD-ARM} ${PAD} L ${PAD+ARM} ${PAD} L ${PAD} ${PAD} L ${PAD} ${PAD+ARM} Z`;
    function makeRevSpark(delay){
      const pathEl = mkEl('path',{d:perimPathRev,fill:'none',stroke:'none'});
      const pathId = 'sr'+Math.random().toString(36).slice(2);
      pathEl.setAttribute('id',pathId);
      svg.appendChild(pathEl);
      const dot = mkEl('circle',{r:'2',fill:'rgba(200,0,10,0.6)'});
      dot.setAttribute('filter','url(#hglow)');
      const mot = mkEl('animateMotion',{dur:'9s',repeatCount:'indefinite',begin:delay+'s'});
      const mpath = mkEl('mpath',{});
      mpath.setAttributeNS('http://www.w3.org/1999/xlink','href','#'+pathId);
      mot.appendChild(mpath);
      dot.appendChild(mot);
      return dot;
    }
    svg.appendChild(makeRevSpark(1.5));
    svg.appendChild(makeRevSpark(6));

    // ── TICK MARKS along edges ────────────────────────────
    const TICK_SPACING = 60;
    function addTicks(x1,y1,x2,y2){
      const dx=x2-x1, dy=y2-y1;
      const len = Math.sqrt(dx*dx+dy*dy);
      const count = Math.floor(len/TICK_SPACING);
      for(let i=1;i<count;i++){
        const t=i/count;
        const tx=x1+dx*t, ty=y1+dy*t;
        // perpendicular tick
        const nx=-dy/len*4, ny=dx/len*4;
        svg.appendChild(mkEl('line',{
          x1:tx-nx,y1:ty-ny,x2:tx+nx,y2:ty+ny,
          stroke:'rgba(200,0,10,0.35)','stroke-width':'1'
        }));
      }
    }
    addTicks(PAD+ARM,PAD,        W-PAD-ARM,PAD);
    addTicks(PAD+ARM,H-PAD,      W-PAD-ARM,H-PAD);
    addTicks(PAD,PAD+ARM,        PAD,H-PAD-ARM);
    addTicks(W-PAD,PAD+ARM,      W-PAD,H-PAD-ARM);
  }

  // Show only when app active
  const observer = new MutationObserver(() => {
    const active = document.getElementById('app').classList.contains('active');
    document.getElementById('hud-frame').classList.toggle('visible', active);
  });
  observer.observe(document.getElementById('app'), {attributes:true,attributeFilter:['class']});

  window.addEventListener('resize', build);
  window.addEventListener('load', build);
  setTimeout(build, 100);
})();

// ══ INIT ════════════════════════════════════════════════════════
window.addEventListener('load', () => {
  const stored = localStorage.getItem('astraUser');
  // intro plays first
});
</script>
</body>
</html>
